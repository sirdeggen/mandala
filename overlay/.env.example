NODE_NAME=mandala
SERVER_PRIVATE_KEY=replace_with_output_of_npm_run_gen-key
HOSTING_URL=http://localhost:8080
MONGO_URL=mongodb://mongodb:27017/mandala
NETWORK=test
SQLITE_FILE=/data/overlay.sqlite
# Optional: point at an Arcade v2 node to make the overlay broadcast accepted
# txs (POST $ARCADE_URL/tx), refresh merkle proofs, and run full SPV (headers +
# merkle-root verification + reorg SSE) via go-chaintracks instead of the local
# scripts-only mode. Leave unset for the local demo.
#ARCADE_URL=https://arcade-v2-us-1.bsvblockchain.tech
#ARCADE_API_KEY=
# Chaintracks defaults to $ARCADE_URL/chaintracks with API prefix /v2; override
# either independently if the chain tracker lives elsewhere.
#CHAINTRACKS_URL=https://arcade-v2-us-1.bsvblockchain.tech/chaintracks
#CHAINTRACKS_API_PREFIX=/v2
