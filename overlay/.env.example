# txs (POST $ARCADE_URL/tx), refresh merkle proofs, and track headers/reorgs
# via its go-chaintracks service. Leave unset for the local scripts-only demo.
#ARCADE_URL=https://arcade-v2-us-1.bsvblockchain.tech
#ARCADE_API_KEY=
